# Genesis Protocol — Environment Configuration
#
# Copy this file to .env and set real values before deploying.
# NEVER commit .env to version control.

# ── Moltbook Adapter (Outbound) ──────────────────────────
# Set MOLTBOOK_API_KEY to enable the adapter.
# Leave unset to run in silent mode (no outbound posts).
#
# Get your key: POST https://www.moltbook.com/api/v1/agents/register
# Docs: https://www.moltbook.com/skill.md
#
# MOLTBOOK_API_KEY=moltbook_sk_your_key_here
# MOLTBOOK_SUBMOLT=general
# MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1
# MOLTBOT_POST_INTERVAL=1800
# MOLTBOT_MAX_RETRIES=2
# MOLTBOT_TIMEOUT_SECS=10

# ── Logging ─────────────────────────────────────────────
RUST_LOG=info
