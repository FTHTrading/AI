# Genesis Protocol — Environment Configuration
#
# Copy this file to .env and set real values before deploying.
# NEVER commit .env to version control.

# ── Moltbot Adapter (Outbound) ──────────────────────────
# Set MOLTBOOK_ENDPOINT to enable the adapter.
# Leave unset to run in silent mode (no outbound posts).
#
# MOLTBOOK_ENDPOINT=https://moltbook.example/api/post
# MOLTBOOK_API_KEY=your-api-key-here
# MOLTBOT_HEARTBEAT_INTERVAL=60
# MOLTBOT_MAX_RETRIES=2
# MOLTBOT_TIMEOUT_SECS=10

# ── Logging ─────────────────────────────────────────────
RUST_LOG=info
